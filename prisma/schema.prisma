generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  url       String
  title     String
  tags      String[] @default([])
  createdAt DateTime @default(now())

  @@index([userId])
}
